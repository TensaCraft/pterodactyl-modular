APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_THEME=pterodactyl
APP_TIMEZONE=UTC
APP_URL=http://panel.example.com
APP_LOCALE=en
APP_ENVIRONMENT_ONLY=true

# Docker Compose mode selection.
# Run `docker compose up -d` from the repository root after choosing one COMPOSE_FILE value.
COMPOSE_PATH_SEPARATOR=;
# Production + Traefik
COMPOSE_FILE=docker-compose.yml;.docker/compose/proxy-traefik.yml
# Production + Nginx Proxy Manager / shared proxy network
# COMPOSE_FILE=docker-compose.yml;.docker/compose/proxy-npm.yml
# Production + direct host port binding
# COMPOSE_FILE=docker-compose.yml;.docker/compose/direct.yml
# Development + NPM / shared proxy network
# COMPOSE_FILE=docker-compose.yml;.docker/compose/dev.yml;.docker/compose/dev-proxy-npm.yml
# Development + Traefik
# COMPOSE_FILE=docker-compose.yml;.docker/compose/dev.yml;.docker/compose/dev-proxy-traefik.yml
# Development + direct host port binding
# COMPOSE_FILE=docker-compose.yml;.docker/compose/dev.yml;.docker/compose/direct.yml

# Shared reverse proxy network name for NPM/Traefik overrides.
PROXY_NETWORK=proxy
# Required only for Traefik overrides. Use the host part of APP_URL.
PANEL_DOMAIN=panel.example.com
TRAEFIK_CERTRESOLVER=letsencrypt
# Optional direct binding mode.
PANEL_BIND_IP=127.0.0.1
PANEL_HTTP_PORT=8080
# Optional dev Wings helpers.
LOCAL_WINGS_PANEL_URL=http://panel
LOCAL_WINGS_ALLOWED_ORIGIN=http://panel.example.com

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=pterodactyl
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=file
QUEUE_CONNECTION=redis
SESSION_DRIVER=file

HASHIDS_SALT=
HASHIDS_LENGTH=8

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Pterodactyl Panel"
# You should set this to your domain to prevent it defaulting to 'localhost', causing
# mail servers such as Gmail to reject your mail.
#
# @see: https://github.com/pterodactyl/panel/pull/3110
# MAIL_EHLO_DOMAIN=panel.example.com
